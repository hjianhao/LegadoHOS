/**
 * RSS 数据模型
 */
export interface RSSSource {
  id: number;
  sourceUrl: string;
  sourceName: string;
  groupId: number;
  enabled: boolean;
  createTime: number;
  updateTime: number;
}

export interface RSSArticle {
  id: number;
  sourceId: number;
  title: string;
  content: string;
  summary: string;
  link: string;
  author: string;
  pubDate: string;
  isRead: boolean;
  isStar: boolean;
  createTime: number;
}
