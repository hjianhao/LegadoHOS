/**
 * @kit.CoreSpeechKit - textToSpeech 引擎类型声明
 * 参考: https://developer.huawei.com/consumer/cn/doc/harmonyos-references/hms-ai-texttospeech
 */
declare module '@kit.CoreSpeechKit' {
  export namespace textToSpeech {
    interface CreateEngineParams {
      language: string;
      person?: number;
      online?: number;   // 1=离线, 0=在线(暂不支持)
      extraParams?: Record<string, string>;
    }

    interface StartResponse {
      requestId: string;
    }
    interface CompleteResponse {
      requestId: string;
    }
    interface StopResponse {
      requestId: string;
    }
    interface SynthesisResponse {
      requestId: string;
    }

    interface SpeakListener {
      onStart?(requestId: string, response: StartResponse): void;
      onComplete?(requestId: string, response: CompleteResponse): void;
      onStop?(requestId: string, response: StopResponse): void;
      onData?(requestId: string, audio: ArrayBuffer, response: SynthesisResponse): void;
      onError?(requestId: string, errorCode: number, errorMessage: string): void;
    }

    interface SpeakParams {
      requestId: string;
      extraParams?: Record<string, Object>;
    }

    interface TextToSpeechEngine {
      speak(text: string, params: SpeakParams): Promise<void>;
      stop(): Promise<void>;
      setListener(listener: SpeakListener): void;
      setParams(params: Record<string, Object>): void;
      isBusy(): boolean;
      shutdown(): void;
    }

    function createEngine(params: CreateEngineParams): Promise<TextToSpeechEngine>;
  }
}
